    - key: lesson1.title
      value: "B\xC0I 1 \u2022 PH\u1EA2N \u0110\xD2N C\u01A0 B\u1EA2N"
    - key: lesson1.objective
      value: "C\xF3 3 vi\xEAn \u0111\u1EA1n t\xEDm x\u1EBFp ngang s\u1EB5n tr\xEAn
        m\xE0n. Ph\u1EA3n \u0111\xF2n \u0111\u1EE7 3 vi\xEAn, v\xE0 ch\u1EC9 \u0111\u01B0\u1EE3c
        t\xEDnh khi \u0111\u1EA1n ph\u1EA3n ch\u1EA1m receiver ph\xEDa tr\xEAn."
    - key: lesson1.hint
      value: "Ph\u1EA3n \u0111\xF2n xong ch\u01B0a t\xEDnh ngay. M\u1ED7i vi\xEAn
        ph\u1EA3i ph\u1EA3n l\u1EA1i v\xE0 ch\u1EA1m receiver m\u1EDBi \u0111\u01B0\u1EE3c
        c\u1ED9ng ti\u1EBFn tr\xECnh."
    - key: lesson1.progress_label
      value: "Ti\u1EBFn tr\xECnh"
    - key: lesson1.banner.title
      value: "B\xE0i 1"
    - key: lesson1.banner.subtitle
      value: "Ph\u1EA3n \u0111\xF2n 3 vi\xEAn t\xEDm v\xE0 \u0111\u1EC3 \u0111\u1EA1n
        ph\u1EA3n ch\u1EA1m receiver ph\xEDa tr\xEAn."
    - key: lesson1.complete.title
      value: "B\xE0i 1 ho\xE0n th\xE0nh"
    - key: lesson1.complete.subtitle
      value: "\u0110\u1EA1n ph\u1EA3n ph\u1EA3i ch\u1EA1m receiver ph\xEDa tr\xEAn
        m\u1EDBi \u0111\u01B0\u1EE3c t\xEDnh."
    - key: lesson2.title
      value: "B\xC0I 2 \u2022 \u0110\u1EA0N XANH / \u0110\u1EA0N T\xCDM"
    - key: lesson2.objective
      value: "C\u1EE9 m\u1ED7i 1 gi\xE2y s\u1EBD c\xF3 c\u1EA3 1 \u0111\u1EA1n xanh
        v\xE0 1 \u0111\u1EA1n t\xEDm. N\xE9 \u0111\u1EA1n xanh, ph\u1EA3n \u0111\xF2n
        \u0111\u1EA1n t\xEDm \u0111\u1EC3 h\u1EA1 c\u1EA3 2 enemy."
    - key: lesson2.hint
      value: "Hai enemy b\u1EAFn c\xF9ng nh\u1ECBp v\xE0 s\u1EBD \u0111\u1ED5i vai
        gi\u1EEFa \u0111\u1EA1n xanh v\xE0 \u0111\u1EA1n t\xEDm."
    - key: lesson2.progress_label
      value: "Enemy c\xF2n l\u1EA1i"
    - key: lesson2.banner.title
      value: "B\xE0i 2"
    - key: lesson2.banner.subtitle
      value: "M\u1ED7i nh\u1ECBp: m\u1ED9t b\xEAn xanh, m\u1ED9t b\xEAn t\xEDm, r\u1ED3i
        \u0111\u1ED5i vai."
    - key: lesson2.complete.title
      value: "B\xE0i 2 ho\xE0n th\xE0nh"
    - key: lesson2.complete.subtitle
      value: "B\u1EA1n \u0111\xE3 n\xE9 \u0111\u1EA1n xanh v\xE0 ph\u1EA3n \u0111\xF2n
        \u0111\xFAng nh\u1ECBp \u0111\u1EA1n t\xEDm."
    - key: lesson3.title
      value: "B\xC0I 3 \u2022 PH\u1EA2N \u0110\xD2N N\xC2NG CAO"
    - key: lesson3.objective
      value: "Enemy s\u1EBD sang 1 lane, b\u1EAFn 1 ph\xE1t r\u1ED3i d\u1EEBng l\u1EA1i.
        H\xE3y \u0111\xFAng nh\u1ECBp \u0111\u1EC3 ph\u1EA3n \u0111\xF2n b\u1EB1ng
        parry."
    - key: lesson3.hint
      value: "Sau m\u1ED7i ph\xE1t b\u1EAFn s\u1EBD c\xF3 kho\u1EA3ng d\u1EEBng r\xF5
        r\xE0ng tr\u01B0\u1EDBc khi enemy \u0111\u1ED5i lane ti\u1EBFp."
    - key: lesson3.progress_label
      value: "Enemy gi\u1EEFa HP"
    - key: lesson3.banner.title
      value: "B\xE0i 3"
    - key: lesson3.banner.subtitle
      value: "Enemy \u0111\u1ED5i 4 lane v\xE0 b\u1EAFn t\u1EEBng nh\u1ECBp ng\u1EAFn
        \u0111\u1EC3 b\u1EA1n \u0111\u1ECDc pattern."
    - key: lesson3.complete.title
      value: "B\xE0i 3 ho\xE0n th\xE0nh"
    - key: lesson3.complete.subtitle
      value: "B\u1EA1n \u0111\xE3 ph\u1EA3n \u0111\xF2n \u1ED5n trong pattern lane
        \u0111\u01A1n gi\u1EA3n h\u01A1n."
    - key: lesson_skill.title
      value: SKILL
    - key: lesson_skill.objective
      value: "Ph\u1EA3n \u0111\xF2n \u0111\u1EC3 n\u1EA1p \u0111\u1EA7y Rage, r\u1ED3i
        d\xF9ng skill \u0111\u1EC3 ph\xE1 barrier."
    - key: lesson_skill.hint
      value: "Ph\u1EA3n \u0111\xF2n s\u1EBD n\u1EA1p Rage. Khi n\xFAt SKILL s\xE1ng,
        d\xF9ng ngay \u0111\u1EC3 ph\xE1 barrier."
    - key: lesson_skill.progress
      value: "Ti\u1EBFn tr\xECnh: n\u1EA1p Rage \u0111\u1EA7y r\u1ED3i d\xF9ng skill
        \u0111\u1EC3 ph\xE1 barrier"
    - key: lesson_skill.banner.title
      value: Skill
    - key: lesson_skill.banner.subtitle
      value: "Ph\u1EA3n \u0111\xF2n s\u1EBD n\u1EA1p Rage. D\xF9ng skill khi thanh
        \u0111\u1EA7y."
    - key: lesson_skill.complete.title
      value: "Skill th\xE0nh c\xF4ng"
    - key: lesson_skill.complete.subtitle
      value: "B\u1EA1n \u0111\xE3 n\u1EA1p Rage v\xE0 d\xF9ng skill \u0111\xFAng
        flow."
